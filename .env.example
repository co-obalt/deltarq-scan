# ============================================================
# DELTARQ Scanner — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Data Layer / Database Configuration ---
DATA_LAYER_ENDPOINT=https://your-project-id.supabase.co
DATA_LAYER_ANON_KEY=your-anon-key
DATA_LAYER_SERVICE_ROLE_KEY=your-service-role-key

# --- Server Configuration ---
PORT=3000
NODE_ENV=development

# --- DELTARQ API Configuration ---
# Used by the CLI tool to upload scan results
DELTARQ_API_URL=http://localhost:3000/api/scans
DELTARQ_DASHBOARD_URL=http://localhost:3000

# --- Optional: Analytics ---
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
